{
  "info": {
    "name": "Blogify API",
    "description": "Core Blogify API requests for authentication, posts, comments, likes, bookmarks, notifications, health checks, and documentation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://<render-domain>"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "post_id",
      "value": ""
    },
    {
      "key": "comment_id",
      "value": ""
    },
    {
      "key": "notification_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health/"
          }
        },
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/docs/"
          }
        },
        {
          "name": "OpenAPI Schema",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/schema/"
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"reader@example.com\",\n  \"username\": \"reader\",\n  \"password\": \"StrongPassword123!\",\n  \"password_confirm\": \"StrongPassword123!\",\n  \"first_name\": \"Reader\",\n  \"last_name\": \"One\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/register/"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"reader@example.com\",\n  \"password\": \"StrongPassword123!\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/login/"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/refresh/"
          }
        },
        {
          "name": "Current User",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{base_url}}/api/v1/auth/me/"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/logout/"
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "List Posts",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/posts/?ordering=newest&page=1&page_size=20"
          }
        },
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Shipping a Django API",
                  "type": "text"
                },
                {
                  "key": "excerpt",
                  "value": "Notes from building a production-ready backend.",
                  "type": "text"
                },
                {
                  "key": "content",
                  "value": "Long-form post content goes here.",
                  "type": "text"
                },
                {
                  "key": "status",
                  "value": "PUBLISHED",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/api/v1/posts/"
          }
        },
        {
          "name": "Retrieve Post",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/posts/{{post_id}}/"
          }
        }
      ]
    },
    {
      "name": "Engagement",
      "item": [
        {
          "name": "List Comments",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/posts/{{post_id}}/comments/"
          }
        },
        {
          "name": "Create Comment",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"This is a thoughtful comment.\"\n}"
            },
            "url": "{{base_url}}/api/v1/posts/{{post_id}}/comments/"
          }
        },
        {
          "name": "Like Post",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{base_url}}/api/v1/posts/{{post_id}}/like/"
          }
        },
        {
          "name": "Bookmark Post",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{base_url}}/api/v1/posts/{{post_id}}/bookmark/"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{base_url}}/api/v1/notifications/"
          }
        },
        {
          "name": "Mark Notification Read",
          "request": {
            "method": "PATCH",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{base_url}}/api/v1/notifications/{{notification_id}}/read/"
          }
        },
        {
          "name": "Mark All Notifications Read",
          "request": {
            "method": "PATCH",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{base_url}}/api/v1/notifications/read-all/"
          }
        }
      ]
    }
  ]
}
